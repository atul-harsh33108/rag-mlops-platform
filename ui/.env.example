# --- UI (Next.js) ---
# Where the Next.js route handlers find the FastAPI RAG backend. In Docker Compose this is
# http://app:8000; in K8s http://mlops-app.mlops.svc:8000; locally http://127.0.0.1:8000.
BACKEND_URL=http://127.0.0.1:8000

# Clerk (demo auth). When these are unset, Clerk middleware becomes a no-op and /api/chat
# falls back to LOCAL_DEV_TENANT (the unauthenticated M1 backend path). Get these from
# Clerk Dashboard > API Keys:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk authorized parties (origins allowed as the JWT `azp`), comma-separated. Must include
# the app's public origin(s). Mirrored into the backend as CLERK_AUTHORIZED_PARTIES.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Local-dev fallback tenant when Clerk is not configured (evals/seed use this too).
LOCAL_DEV_TENANT=acme