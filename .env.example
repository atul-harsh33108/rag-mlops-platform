# ============================================================================
# RAG MLOps Platform — environment variables
# Copy to .env and fill in. NEVER commit the real .env.
# ============================================================================

# --- General ---
TZ=UTC
ENV=dev
LOG_LEVEL=INFO

# --- Corpus / data ---
CORPUS_VERSION=1
# Domain subset of tarekmasryo/rag-qa-logs-corpus-data to seed
SEED_DOMAINS=support_faq,product_docs
SEED_DOC_COUNT=500

# --- Qdrant (vector DB) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=docs
QDRANT_API_KEY=

# --- TEI (embeddings, BGE-M3) ---
TEI_HOST=tei
TEI_PORT=80
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024            # Matryoshka-truncated to 768 at M3 if needed

# --- LiteLLM gateway (added at M3; Ollama locally before that) ---
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-llm-master-CHANGE_ME
LITELLM_API_KEY=sk-llm-tenant-CHANGE_ME   # sent by the app as Bearer; any key once master_key is set
LITELLM_DB_URL=postgresql+psycopg://litellm:litellm@postgres:5432/litellm

# --- MLflow Prompt Registry (M3): app loads the system prompt by alias `production` ---
# MLFLOW_TRACKING_URI + MLFLOW_S3_ENDPOINT_URL + AWS keys are in the MLflow section below.
RAG_PROMPT_NAME=rag-system
RAG_PROMPT_ALIAS=production

# --- Ollama (local serving, M1) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_NUM_CTX=8192

# --- vLLM (prod serving, M5) ---
VLLM_MODEL=s3://mlops-models/qwen3-14b-awq
VLLM_MAX_MODEL_LEN=8192

# --- Redis (semantic cache + rate limit) ---
REDIS_URL=redis://redis:6379/0
LANGCACHE_DISTANCE_THRESHOLD=0.90   # cosine; 0.88 FAQ, 0.94-0.96 legal/medical

# --- Postgres (app metadata, LiteLLM spend, tenant keys) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mlops
POSTGRES_USER=mlops
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+psycopg://mlops:CHANGE_ME@postgres:5432/mlops

# --- Langfuse (observability, M2) ---
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME
# Self-host infra (compose.mlops.yml):
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME
LANGFUSE_SALT=CHANGE_ME
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=CHANGE_ME
S3_STORAGE_BUCKET=langfuse-blobs
S3_STORAGE_REGION=us-east-1
S3_STORAGE_ENDPOINT=http://minio:9000
S3_STORAGE_ACCESS_KEY=CHANGE_ME
S3_STORAGE_SECRET_KEY=CHANGE_ME

# --- MLflow (tracking + registry, M2) ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# --- OpenLLMetry / OTel (M2) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=rag-app

# --- Airflow orchestration (M3) ---
AIRFLOW_ADMIN_PASSWORD=admin          # local dev only — set a real secret in prod
DEFAULT_TENANT=acme                   # tenant the ingest DAG indexes the corpus into
# In-network service URLs the DAGs call (compose sets these on the airflow container):
APP_BASE_URL=http://app:8000
QDRANT_BASE_URL=http://qdrant:6333

# --- Auth (M6) ---
# Backend (FastAPI) verifies Clerk session JWTs against the JWKS URL; org claim o.id = tenant.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# JWKS for backend JWT verify (Clerk Frontend API /.well-known/jwks.json). When unset, auth
# is disabled and /chat falls back to the body tenant (M1 mode, used by evals/seed).
CLERK_JWKS_URL=
CLERK_AUTHORIZED_PARTIES=http://localhost:3002  # comma-separated allowed azp origins (UI)
JWT_ISSUER=
JWT_AUDIENCE=rag-platform
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# --- UI (M6) ---
# Where the Next.js route handlers find the backend. Local: http://127.0.0.1:8000;
# compose: http://app:8000. NEXT_PUBLIC_* are inlined into the client bundle at build time.
BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
LOCAL_DEV_TENANT=acme

# --- Billing + metering + sampled eval (M7) ---
# Lago (open-source billing). LiteLLM's `lago` callback reports spend as the `llm-spend`
# billable metric; the app manages Lago customer/subscription lifecycle. See
# docs/runbooks/saas.md + docs/decisions/0010-billing-lago-stripe.md.
LAGO_API_BASE=
LAGO_API_KEY=
LAGO_WEBHOOK_HOST=
LAGO_BILLABLE_METRIC_CODE=llm-spend
# Stripe — webhook updates tenant plan + budget on subscription events.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Clerk — webhook syncs Clerk org -> tenant row (group_id = org id).
CLERK_WEBHOOK_SECRET=
# Production-sampled eval: fraction of /chat turns judged for the 7-day regression alert.
EVAL_SAMPLE_RATE=0.05
# Judge model (routed via LiteLLM `judge`; locally -> Ollama, EKS -> Bedrock Claude).
JUDGE_MODEL=judge

# --- AWS (M5) ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
EKS_CLUSTER_NAME=mlops-prod
S3_MODEL_BUCKET=mlops-models
S3_TF_STATE_BUCKET=mlops-tf-state
DYNAMO_LOCK_TABLE=mlops-tf-lock